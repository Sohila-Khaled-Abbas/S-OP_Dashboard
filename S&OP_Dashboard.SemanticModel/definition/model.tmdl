model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-001
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 01_Staging

	annotation PBI_QueryGroupOrder = 0

queryGroup 02_Dimensions

	annotation PBI_QueryGroupOrder = 1

queryGroup 03_Facts

	annotation PBI_QueryGroupOrder = 2

queryGroup 04_Support

	annotation PBI_QueryGroupOrder = 3

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Address","CAMPAIGN_LOG","CUST_MASTER","INVOICES","ORDERS_2025","ORDERS_2026","campaign_skus","cities","customer_contacts","exchange_rates","inventory","invoice_lines","order_line_items","payments","products","regions","sales_targets","Security","shipments","subcategories","user_details","DimCustomer","DimProduct","DimOrderFlags","DimGeo","DimCampaign","DimDate","orders","channels","FactSales","FactInventory","FactCampaignSpend","FactPromotionCoverage","FactOrderFulfillment","FactSalesTargets"]

annotation PBI_ProTooling = ["DevMode","TMDLView_Desktop"]

ref table DimCustomer
ref table DimProduct
ref table DimOrderFlags
ref table FactSales
ref table DimGeo
ref table FactInventory
ref table DimCampaign
ref table FactCampaignSpend
ref table FactPromotionCoverage
ref table FactOrderFulfillment
ref table FactSalesTargets
ref table Security
ref table DimDate

ref cultureInfo en-US

ref role 'Regional Sales Rep'
ref role 'Executive'
ref role 'Admin'

